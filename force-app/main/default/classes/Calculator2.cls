public with sharing class Calculator2 {
    public Calculator2() {
        

    }
    public integer add(integer a, integer b)
    {
        return a+b;
    }
    public integer div(integer a, integer b)
    {
        return a/b;
    }
    public integer min(integer a, integer b)
    {
        return a-b;
    }
    public integer mut(integer a, integer b)
    {
        return a*b;
    }

}